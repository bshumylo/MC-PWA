            "maxLength": 255,
            "readOnly": true
        },
        "authKey": {
            "type": "varchar",
            "maxLength": 100,
            "readOnly": true
        },
        "platform": {
            "type": "varchar",
            "maxLength": 60,
            "readOnly": true
        },
        "userAgent": {
            "type": "varchar",
            "maxLength": 255,
            "readOnly": true
        },
        "createdAt": {
